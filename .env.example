# Christina Pfeiffer Supabase project (read-only website content + email templates)
NEXT_PUBLIC_CP_SUPABASE_URL=
NEXT_PUBLIC_CP_SUPABASE_ANON_KEY=

# Gmail (sends the coaching-request emails). Use a Gmail App Password, not the account password.
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Optional: enables recording each request in the dashboard inbox (booking_requests).
# Without it, emails still send — the request just isn't logged to the inbox.
SUPABASE_SERVICE_ROLE_KEY=
